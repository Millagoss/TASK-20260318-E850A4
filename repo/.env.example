POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=activity_db
JWT_SECRET=change-me-super-secret-jwt-key
# Any non-empty string works (SHA256-derived); or paste Fernet.generate_key().decode()
WHITELIST_ENCRYPTION_KEY=dev-change-me-whitelist-secret
FEATURE_DUPLICATE_CHECK=false

# Frontend (Vite): browser calls this origin for API. Default in code is http://localhost:8000 if unset.
VITE_API_BASE=http://localhost:8000
